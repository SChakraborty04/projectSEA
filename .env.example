BETTER_AUTH_SECRET="your_better_auth_secret_here"
BETTER_AUTH_URL="http://localhost:3000"
DATABASE_URL="postgresql://username:password@hostname:5432/dbname?sslmode=require"
CORSAIR_KEK="your_corsair_kek_encryption_key_here"

# ── Public-facing URL ──────────────────────────────────────────────────────
# This is the single source of truth for the app's public URL.
# It is used to build OAuth redirect URIs, so it MUST match exactly what is
# registered in the Google Cloud Console.
#
# Switch between environments by changing only this one variable:
#   Local dev:   APP_URL=http://localhost:3000
#   ngrok:       APP_URL=https://your-ngrok-subdomain.ngrok-free.dev
#   Production:  APP_URL=https://yourdomain.com
APP_URL="http://localhost:3000"

OPENROUTER_API_KEY="sk-or-v1-your_openrouter_api_key"
VAPI_PRIVATE_API_KEY="your_vapi_private_key"
NEXT_PUBLIC_VAPI_PUBLIC_KEY="your_vapi_public_key"
CARTESIA_API_KEY="your_cartesia_api_key"
QSTASH_URL="https://qstash.upstash.io"
QSTASH_TOKEN="your_qstash_token"
QSTASH_CURRENT_SIGNING_KEY="your_qstash_current_signing_key"
QSTASH_NEXT_SIGNING_KEY="your_qstash_next_signing_key"

# Cloudflare R2 Settings (Optional - fallbacks to Postgres inline storage if not configured)
# R2_ACCOUNT_ID="your_r2_account_id"
# R2_ACCESS_KEY_ID="your_r2_access_key_id"
# R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
# R2_BUCKET_NAME="your_r2_bucket_name"

# Telegram Bot Integration Settings
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"

# Phishing Detection API settings (Hugging Face Spaces)
PHISHING_DETECTION_API_URL="https://your-hf-space.hf.space/analyze"
HUGGINGFACE_API_KEY="your_hf_api_key_optional"

# Google Signin OAuth credentials
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
MAILTRAP_TOKEN="hello-world"
CRON_SECRET="test-it"
